# Версия (одна для всех компонентов)
VERSION=v3.10.7

# Docker образы: one-pam/core:v3.10.7, one-pam/web:v3.10.7, ...
IMAGE_PREFIX=one-pam

# Префикс имён контейнеров
PREFIX=one-pam

# Секреты (сгенерировать: make secrets)
SECRET_KEY=CHANGE_ME
BOOTSTRAP_TOKEN=CHANGE_ME
DB_PASSWORD=CHANGE_ME
DB_ROOT_PASSWORD=CHANGE_ME
REDIS_PASSWORD=CHANGE_ME

# БД
DB_NAME=jumpserver
DB_USER=jumpserver

# Порты
HTTP_PORT=80
HTTPS_PORT=443
SSH_PORT=2222

# Логирование
LOG_LEVEL=ERROR
